{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/?action=register",
      "body": {"email": "test_auction_k3@example.com", "name": "Тест Пользователь", "password": "testpass123"},
      "expectedStatus": 201,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with wrong password",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "test_auction_k3@example.com", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Get me without token",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}